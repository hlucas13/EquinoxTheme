{
    "name": "equinox-colors",
    "version": "0.0.7",
    "description": "Multi-platform ergonomic theme system for VS Code, JetBrains IDEs, and macOS Terminal. Eliminates cognitive fatigue and strictly adheres to WCAG AAA contrast standards.",
    "author": "Equinox Team",
    "contributors": [
        {
            "name": "Homero P.",
            "url": "https://github.com/hlucas13"
        },
        {
            "name": "Beatriz O.",
            "url": "https://github.com/beatrizsaoliveira"
        }
    ],
    "license": "MIT",
    "type": "commonjs",
    "scripts": {
        "build": "node build.js",
        "prebuild": "npm run clean",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/ playground/",
        "clean": "rm -rf dist",
        "dev": "vite",
        "playground": "vite",
        "preview": "vite preview",
        "prepare": "husky",
        "test": "vitest run",
        "test:watch": "vitest",
        "icons": "node scripts/generate-icons.js",
        "package": "node scripts/package-marketplace.js",
        "package:vscode": "node scripts/package-marketplace.js vscode",
        "package:jetbrains": "node scripts/package-marketplace.js jetbrains"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^20.10.6",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "archiver": "^7.0.1",
        "esbuild": "^0.27.4",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sharp": "^0.34.5",
        "typescript": "^5.9.3",
        "vite": "^6.3.5",
        "vitest": "^4.1.7"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "playground/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{html,css,json,md}": "prettier --write"
    },
    "keywords": [
        "theme",
        "vscode",
        "jetbrains",
        "terminal",
        "ergonomic",
        "wcag",
        "contrast",
        "syntax-highlighting",
        "color-scheme"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hlucas13/EquinoxTheme.git"
    },
    "bugs": {
        "url": "https://github.com/hlucas13/EquinoxTheme/issues"
    },
    "homepage": "https://hlucas13.github.io/EquinoxTheme",
    "icon": "images/icon.png",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
