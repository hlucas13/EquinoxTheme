{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020", "DOM"],
        "types": ["node"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "noEmit": true
    },
    "include": [
        "src/**/*",
        "playground/**/*",
        "tests/**/*",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
